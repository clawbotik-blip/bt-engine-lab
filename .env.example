# Quote & Contact Form
QUOTE_WEBHOOK_URL=          # Webhook URL to receive quote form submissions (e.g. Zapier, Make, n8n)
CONTACT_WEBHOOK_URL=        # Webhook URL to receive contact form submissions
FORM_FROM_EMAIL=            # Sender email address for form notifications
FORM_TO_EMAIL=              # Recipient email address (e.g. berdia@btenginelabllc.com)

# Supabase (optional - for logging quote requests to a database)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=   # Google Analytics 4 measurement ID
